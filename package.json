{
  "name": "create-shadcn-start",
  "version": "0.0.2",
  "description": "Interactive scaffolder for shadcn-based projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kapishdima/create-shadcn-start.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": {
    "name": "kapishdima",
    "url": "https://twitter.com/kapish_dima"
  },
  "type": "module",
  "bin": {
    "create-shadcn-start": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "src/data"
  ],
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --project unit",
    "test:components": "vitest run --project components",
    "test:e2e": "vitest run --project e2e",
    "test": "vitest run",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@xstate/react": "^5.0.0",
    "chalk": "^5.6.2",
    "cli-spinners": "^3.4.0",
    "execa": "^9.6.1",
    "ink": "^7.0.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "mnemonist": "^0.40.3",
    "open": "^11.0.0",
    "package-manager-detector": "^1.6.0",
    "react": "^19.2.5",
    "shadcn": "^4.6.0",
    "xstate": "^5.18.2"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tmp-promise": "^3.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.5"
  }
}
